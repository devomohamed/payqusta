NODE_ENV=production
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-strong-random-secret
CLIENT_URL=https://payqusta.store
APP_URL=https://payqusta.store
PLATFORM_ROOT_DOMAIN=payqusta.store

# Optional but recommended for production monitoring
OPS_BEARER_TOKEN=replace-with-a-long-random-token
OPS_MONITOR_URL=
CORS_ALLOWED_ORIGINS=
API_JSON_LIMIT=10mb
API_FORM_LIMIT=2mb
PORTAL_AUTH_RATE_LIMIT_MAX=20
PORTAL_ENROLLMENT_RATE_LIMIT_MAX=10
WEBHOOK_RATE_LIMIT_MAX=120

# Optional but required for live payment validation
PAYMOB_ENABLED=false
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# Optional but required for live shipping validation
BOSTA_API_KEY=
BOSTA_WEBHOOK_SECRET=

# Optional but recommended for subscription webhook protection
SUBSCRIPTION_WEBHOOK_SECRET=
SUBSCRIPTION_INSTAPAY_WEBHOOK_SECRET=
SUBSCRIPTION_VODAFONE_CASH_WEBHOOK_SECRET=
SUBSCRIPTION_PAYMOB_WEBHOOK_SECRET=
SUBSCRIPTION_STRIPE_WEBHOOK_SECRET=

# Durable upload storage for Cloud Run
# Preferred: gcs
# Approved fallback when GCS is not ready yet: mongodb
UPLOAD_STORAGE=mongodb
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GCS_PUBLIC_BASE_URL=
GCS_MAKE_UPLOADS_PUBLIC=false
